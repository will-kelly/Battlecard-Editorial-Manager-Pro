        "High risk claims flagged"
      ]
    },
    {
      "id": "03_outline",
      "name": "Outline development",
      "outputs": [
        "battlecard_outline",
        "talk_track"
      ],
      "exit_criteria": [
        "Sales scannable",
        "Differentiators clear"
      ]
    },
    {
      "id": "04_draft",
      "name": "Drafting v1",
      "outputs": [
