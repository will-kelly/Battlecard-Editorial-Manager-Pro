        "Audience defined",
        "Primary competitor defined",
        "Use case defined",
        "Claim boundaries documented"
      ]
    },
    {
      "id": "02_claims_mapping",
      "name": "Claims mapping and sourcing",
      "outputs": [
        "claims_map",
        "risk_register"
      ],
      "exit_criteria": [
